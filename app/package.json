{
  "name": "formulaverse",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "npm run validate:catalog && npm run check:seo && npm run og && astro build && npm run sitemap",
    "build:fast": "astro build",
    "preview": "astro preview",
    "og": "node --import tsx/esm scripts/generate-formula-og.mjs",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "check:seo": "node --import tsx/esm scripts/check-seo.mjs",
    "validate:catalog": "node --import tsx/esm scripts/validate-catalog.mjs",
    "typecheck": "astro check && tsc --noEmit",
    "test": "vitest run",
    "deploy": "wrangler pages deploy dist --project-name=quickcalci-formulas"
  },
  "dependencies": {
    "@astrojs/react": "^4.2.0",
    "@astrojs/sitemap": "^3.2.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@fontsource/space-mono": "^5.2.5",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-three/drei": "^9.0.0",
    "@react-three/fiber": "^8.0.0",
    "@tailwindcss/vite": "^4.1.8",
    "astro": "^5.7.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^11.18.2",
    "gsap": "^3.15.0",
    "lucide-react": "^0.507.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "roughjs": "^4.6.6",
    "sonner": "^1.5.0",
    "tailwind-merge": "^3.2.0",
    "tailwindcss": "^4.1.8",
    "three": "^0.176.0",
    "tw-animate-css": "^1.3.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/three": "^0.176.0",
    "sharp": "^0.34.5",
    "tsx": "^4.22.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.0.0"
  }
}
