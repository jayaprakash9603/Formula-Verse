---
import ToolLayout from "@/layouts/ToolLayout.astro";
import JsonLd from "@/components/seo/JsonLd.astro";
import FormulaVisualizerEngine from "@/engines/formula-visualizer/FormulaVisualizerEngine";
import { FORMULA_SLUGS_LIVE, getBySlug } from "@/lib/formulas";
import { SITE_NAME, SITE_URL } from "@/lib/site";

export function getStaticPaths() {
  return FORMULA_SLUGS_LIVE.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const config = getBySlug(slug)!;
const pageUrl = `${SITE_URL}/tools/${slug}`;

const learningJsonLd = slug === "pythagorean-theorem-visualizer" ? {
  "@context": "https://schema.org",
  "@type": "LearningResource",
  name: "The Pythagorean Theorem — Interactive Visual Guide",
  description: config.seo.description,
  url: pageUrl,
  educationalLevel: "Beginner",
  learningResourceType: "Interactive visualization",
  teaches: "Pythagorean theorem a² + b² = c²",
  provider: { "@type": "Organization", name: SITE_NAME, url: SITE_URL },
} : null;
---
<ToolLayout config={config} subPage="index">
  {learningJsonLd && (
    <Fragment slot="head">
      <JsonLd data={learningJsonLd} />
    </Fragment>
  )}
  <FormulaVisualizerEngine slug={slug} client:only="react" />
</ToolLayout>
