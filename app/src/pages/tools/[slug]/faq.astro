---
import ToolLayout from "@/layouts/ToolLayout.astro";
import SubPageNav from "@/components/tool/SubPageNav.astro";
import { FORMULA_SLUGS_LIVE, getBySlug } from "@/lib/formulas";

export function getStaticPaths() {
  return FORMULA_SLUGS_LIVE.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const config = getBySlug(slug)!;
---
<ToolLayout config={config} subPage="faq">
  <div class="w-full px-4 sm:px-6 pb-20">
    <SubPageNav slug={config.slug} current="faq" />

    <h1 class="font-display font-bold text-3xl sm:text-4xl mb-4">
      {config.name} — FAQ
    </h1>
    <p class="text-muted-foreground text-lg mb-8">
      Frequently asked questions about {config.name} ({config.shortForm}).
    </p>

    <div class="space-y-6">
      {config.faq.map((item, i) => (
        <div class="neu-raised rounded-xl p-5">
          <h2 class="font-semibold text-base flex items-start gap-2 mb-3">
            <span class="text-primary shrink-0">Q{i + 1}.</span>
            {item.q}
          </h2>
          <p class="text-muted-foreground text-sm leading-relaxed">{item.a}</p>
        </div>
      ))}
    </div>

    <div class="mt-10 pt-6 relative">
      <div class="absolute top-0 left-0 right-0 neu-divider"></div>
      <p class="text-sm text-muted-foreground">
        Have more questions? Try the interactive calculator at{" "}
        <a href={`/tools/${config.slug}`} class="text-primary hover:underline">
          /tools/{config.slug}
        </a>
      </p>
    </div>
  </div>
</ToolLayout>
