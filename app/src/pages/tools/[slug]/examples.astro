---
import ToolLayout from "@/layouts/ToolLayout.astro";
import SubPageNav from "@/components/tool/SubPageNav.astro";
import { FORMULA_SLUGS_LIVE, getBySlug } from "@/lib/formulas";

export function getStaticPaths() {
  return FORMULA_SLUGS_LIVE.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const config = getBySlug(slug)!;
---
<ToolLayout config={config} subPage="examples">
  <div class="w-full px-4 sm:px-6 pb-20">
    <SubPageNav slug={config.slug} current="examples" />

    <h1 class="font-display font-bold text-3xl sm:text-4xl mb-4">
      {config.name} — Worked Examples
    </h1>
    <p class="text-muted-foreground text-lg mb-8">
      Five real-world examples demonstrating the {config.name} formula ({config.shortForm}).
    </p>

    <div class="flex flex-col gap-6">
      {config.examples.map((ex, i) => (
        <div class="neu-raised rounded-xl bg-card p-5">
          <div class="flex items-start gap-3 mb-3">
            <span class="shrink-0 w-8 h-8 rounded-full bg-primary/20 text-primary text-sm font-bold flex items-center justify-center">
              {i + 1}
            </span>
            <div>
              <h2 class="font-semibold text-base">{ex.title}</h2>
              <p class="text-xs text-muted-foreground">{ex.description}</p>
            </div>
          </div>
          <div class="grid grid-cols-2 gap-3 mt-3">
            <div class="neu-inset rounded-md bg-muted/30 p-3">
              <div class="text-xs text-muted-foreground uppercase tracking-wide mb-2">Inputs</div>
              {Object.entries(ex.inputs).map(([k, v]) => (
                <div class="flex justify-between text-sm font-mono">
                  <span class="text-primary">{k}</span>
                  <span>{v}</span>
                </div>
              ))}
            </div>
            <div class="neu-flat rounded-md bg-primary/5 p-3">
              <div class="text-xs text-muted-foreground uppercase tracking-wide mb-2">Result</div>
              {Object.entries(ex.expected).map(([k, v]) => (
                <div class="flex justify-between text-sm font-mono">
                  <span class="text-primary font-semibold">{k}</span>
                  <span class="font-bold">{v}</span>
                </div>
              ))}
            </div>
          </div>
          <div class="mt-3 text-right">
            <a
              href={`/tools/${config.slug}?${Object.entries(ex.inputs).map(([k, v]) => `${k}=${v}`).join("&")}`}
              class="text-xs text-primary hover:underline"
            >
              Try this example →
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</ToolLayout>
