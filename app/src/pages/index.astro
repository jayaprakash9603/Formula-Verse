---
import BaseLayout from "@/layouts/BaseLayout.astro";
import FormulaAnimCard from "@/components/cards/FormulaAnimCard";
import FormulaMarquee from "@/components/site/FormulaMarquee";
import Icon from "@/components/icons/Icon.astro";
import { getFeaturedFormulas, getLiveFormulas } from "@/lib/formulas";
import { SITE_NAME, SITE_DESCRIPTION, SITE_URL } from "@/lib/site";

const featured = getFeaturedFormulas(6);
const all = getLiveFormulas();

/* ─── Build animation frames for each card (server-side) ─── */
function escRe(s: string) { return s.replace(/[.*+?^${}()|[\]\\]/g, "\\$&"); }

function buildFrames(config: (typeof featured)[0]): string[] {
  const out = config.outputs[0];
  const ex  = config.examples?.[0];

  if (!ex) return [config.latex, `${out.symbol} = ?`];

  const frames: string[] = [config.latex];
  let   current = config.latex;

  for (const v of config.vars) {
    const val = ex.inputs[v.id];
    if (val === undefined) continue;

    const next = current.replace(
      new RegExp(`(?<![a-zA-Z\\\\])${escRe(v.symbol)}(?![a-zA-Z])`, "g"),
      String(val),
    );

    if (next !== current) {
      frames.push(next);
      current = next;
    }
  }

  let resLatex = `${out.symbol} = ${ex.expected[out.id] ?? "?"}`;
  if (out.unit) resLatex += `\\;\\text{${out.unit}}`;

  if (resLatex !== current) frames.push(resLatex);

  return frames;
}

const cardData = featured.map((f) => ({
  slug: f.slug,
  name: f.name,
  tagline: f.tagline,
  category: f.category,
  vars: f.vars.map((v) => ({ symbol: v.symbol })),
  animFrames: buildFrames(f),
}));

const categories = [
  { key: "math",        icon: "calculator",    label: "Mathematics" },
  { key: "physics",     icon: "zap",           label: "Physics" },
  { key: "finance",     icon: "trending-up",   label: "Finance" },
  { key: "chemistry",   icon: "flask-conical", label: "Chemistry" },
  { key: "engineering", icon: "settings",      label: "Engineering" },
];

const categoryCounts: Record<string, number> = {};
for (const c of categories) {
  categoryCounts[c.key] = all.filter((f) => f.category === c.key).length;
}

const stats = [
  { value: `${all.length}+`, label: "Formulas" },
  { value: "5",              label: "Categories" },
  { value: "3D",             label: "Visualizations" },
  { value: "Live",           label: "Substitution" },
  { value: "0",              label: "Sign-ups" },
];
---
<BaseLayout
  title={`${SITE_NAME} — Interactive Formula Visualizer`}
  description={SITE_DESCRIPTION}
  canonical={SITE_URL}
>
  <!-- ─────────────────────────── HERO ─────────────────────────── -->
  <section class="relative overflow-hidden">
    <!-- background layers -->
    <div class="absolute inset-0 hero-grid-bg pointer-events-none" />
    <div class="absolute inset-0 hero-brand-glow pointer-events-none" />

    <div class="relative w-full px-4 sm:px-6 md:px-10 lg:px-16 pt-20 pb-20 sm:pt-28 sm:pb-28 grid grid-cols-1 xl:grid-cols-[1.05fr_1fr] gap-16 items-center">

      <!-- Left: copy -->
      <div class="reveal-on-scroll max-w-2xl">
        <div
          class="inline-flex items-center gap-2 neu-flat rounded-full px-3.5 py-1.5 text-xs font-medium mb-7"
          style="color: var(--brand); background: var(--brand-soft);"
        >
          <span class="relative flex h-1.5 w-1.5">
            <span class="absolute inset-0 rounded-full animate-ping" style="background: var(--brand); opacity: 0.5;" />
            <span class="relative inline-flex h-1.5 w-1.5 rounded-full" style="background: var(--brand);" />
          </span>
          Interactive · Free · No Sign-up
        </div>

        <h1 class="font-display font-bold text-5xl sm:text-6xl lg:text-7xl mb-6 leading-[1.04] tracking-tight">
          Understand every<br />
          formula <span class="underline-brand">visually</span>.
        </h1>

        <p class="text-muted-foreground text-base sm:text-lg max-w-xl mb-10 leading-relaxed">
          {SITE_DESCRIPTION}
        </p>

        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href="/formulas"
            class="inline-flex items-center justify-center gap-2 neu-raised neu-interactive rounded-xl px-7 py-3.5 font-semibold text-sm"
            style="background: var(--brand); color: var(--primary-foreground);"
            onmouseover="this.style.background='var(--brand-hover)'"
            onmouseout="this.style.background='var(--brand)'"
          >
            Browse all formulas
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a
            href="/tools/pythagorean-theorem-visualizer"
            class="inline-flex items-center justify-center gap-2 neu-flat neu-interactive rounded-xl px-7 py-3.5 font-semibold text-sm bg-background text-foreground"
          >
            <Icon name="triangle" size={15} />
            Try a live demo
          </a>
        </div>

        <div class="mt-10 flex items-center gap-6 text-xs text-muted-foreground">
          <div class="flex items-center gap-2">
            <Icon name="check" size={14} style="color: var(--brand)" />
            No account required
          </div>
          <div class="flex items-center gap-2">
            <Icon name="check" size={14} style="color: var(--brand)" />
            Runs in your browser
          </div>
        </div>
      </div>

      <!-- Right: orbit composition -->
      <div class="relative hidden xl:flex items-center justify-center h-[520px]">
        <!-- pulsing brand ring -->
        <div
          class="absolute rounded-full animate-ring-pulse"
          style="width: 360px; height: 360px; border: 1px solid var(--brand-mid);"
        />
        <div
          class="absolute rounded-full"
          style="width: 480px; height: 480px; border: 1px dashed var(--hairline);"
        />

        <!-- center disc -->
        <div
          class="relative flex items-center justify-center rounded-full font-display font-bold text-3xl"
          class="neu-raised"
          style="width: 140px; height: 140px; background: var(--card); color: var(--brand);"
        >
          ƒ(x)
        </div>

        <!-- orbiting formula tiles -->
        <div class="absolute inset-0 animate-orbit pointer-events-none">
          <div class="absolute top-[8%] left-1/2 -translate-x-1/2">
            <div class="neu-raised rounded-2xl px-5 py-3.5 font-mono text-sm font-semibold animate-formula-float bg-card text-foreground">
              a² + b² = c²
            </div>
          </div>
          <div class="absolute bottom-[12%] left-[6%]">
            <div class="neu-raised rounded-2xl px-5 py-3.5 font-mono text-sm font-semibold animate-formula-float bg-card text-foreground"
                 style="animation-delay: 1.2s;">
              A = πr²
            </div>
          </div>
          <div class="absolute bottom-[20%] right-[4%]">
            <div class="neu-raised rounded-2xl px-5 py-3.5 font-mono text-sm font-semibold animate-formula-float bg-card text-primary"
                 style="animation-delay: 0.6s;">
              E = mc²
            </div>
          </div>
        </div>

        <!-- counter-orbiting dot decorations -->
        <div class="absolute inset-0 animate-orbit-reverse pointer-events-none">
          <span class="absolute top-1/2 left-[2%] h-2 w-2 rounded-full" style="background: var(--brand);" />
          <span class="absolute top-[10%] right-[12%] h-1.5 w-1.5 rounded-full" style="background: var(--brand-mid);" />
          <span class="absolute bottom-[6%] left-[40%] h-2 w-2 rounded-full" style="background: var(--foreground); opacity: 0.4;" />
        </div>
      </div>
    </div>

    <!-- bottom hairline -->
    <div class="absolute bottom-0 left-0 right-0 neu-divider" />
  </section>

  <!-- ─────────────────────── TRUST / MARQUEE ─────────────────────── -->
  <FormulaMarquee client:visible />

  <!-- ────────────────────────── STATS ────────────────────────── -->
  <section>
    <div class="page-wrap grid grid-cols-2 sm:grid-cols-5 reveal-on-scroll">
      {stats.map((s, i) => (
        <div
          class="flex flex-col items-center justify-center gap-1 py-8 text-center"
        >
          <span class="font-display font-bold text-3xl sm:text-4xl tracking-tight" style="color: var(--brand);">{s.value}</span>
          <span class="text-[11px] uppercase tracking-widest text-muted-foreground">{s.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ─────────────────── FEATURED VISUALIZERS ─────────────────── -->
  <section class="w-full page-wrap py-20 sm:py-24">
    <div class="reveal-on-scroll flex items-end justify-between mb-10 sm:mb-12 gap-6 flex-wrap">
      <div>
        <div class="text-[11px] uppercase tracking-widest text-muted-foreground mb-3">— Popular</div>
        <h2 class="font-display font-bold text-3xl sm:text-4xl tracking-tight mb-2">Visualizers worth a hover</h2>
        <p class="text-sm sm:text-base text-muted-foreground max-w-xl">Hover any card to watch the formula come alive with live value substitution.</p>
      </div>
      <a
        href="/formulas"
        class="hidden sm:inline-flex items-center gap-1.5 text-sm font-semibold transition-opacity hover:opacity-70"
        style="color: var(--brand);"
      >
        View all {all.length}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>

    <div class="reveal-on-scroll grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {cardData.map((card) => (
        <FormulaAnimCard
          client:visible
          slug={card.slug}
          name={card.name}
          tagline={card.tagline}
          category={card.category}
          vars={card.vars}
          animFrames={card.animFrames}
        />
      ))}
    </div>

    <div class="text-center mt-8 sm:hidden">
      <a href="/formulas" class="text-sm font-semibold" style="color: var(--brand);">View all {all.length} visualizers →</a>
    </div>
  </section>

  <!-- ─────────────────────── SHOWCASE ─────────────────────── -->
  <section class="bg-card">
    <div class="w-full page-wrap py-20 sm:py-28">
      <div class="reveal-on-scroll text-center max-w-2xl mx-auto mb-14">
        <div class="text-[11px] uppercase tracking-widest text-muted-foreground mb-3">— Live engine</div>
        <h2 class="font-display font-bold text-3xl sm:text-5xl tracking-tight mb-4">Watch math substitute itself.</h2>
        <p class="text-sm sm:text-base text-muted-foreground">
          Every visualizer breaks a formula into frames — the abstract form, each variable replaced with real numbers, then the result. No clicks. No magic. Just clarity.
        </p>
      </div>

      <!-- Terminal-style showcase card -->
      <div
        class="reveal-on-scroll mx-auto max-w-3xl neu-raised rounded-2xl overflow-hidden bg-background"
      >
        <!-- top bar -->
        <div class="flex items-center justify-between px-5 py-3">
          <div class="flex items-center gap-1.5">
            <span class="h-2.5 w-2.5 rounded-full" style="background: var(--muted);" />
            <span class="h-2.5 w-2.5 rounded-full" style="background: var(--muted);" />
            <span class="h-2.5 w-2.5 rounded-full" style="background: var(--brand);" />
          </div>
          <div class="text-[10px] uppercase tracking-widest text-muted-foreground font-mono">kinetic-energy.ƒ</div>
          <div class="text-[10px] text-muted-foreground font-mono">live</div>
        </div>

        <!-- frames -->
        <div class="grid grid-cols-1 sm:grid-cols-3 divide-y sm:divide-y-0 sm:divide-x" style="--tw-divide-opacity:1;">
          {[
            { label: "Abstract", body: "KE = ½ m v²" },
            { label: "Substitute", body: "KE = ½ · 4 · 10²" },
            { label: "Result", body: "KE = 200 J", highlight: true },
          ].map((f, i) => (
            <div class="px-6 py-10 flex flex-col items-center gap-3" style={`border-color: var(--border); ${i === 1 ? "background: var(--muted);" : ""}`}>
              <span class="text-[10px] uppercase tracking-widest text-muted-foreground">{f.label}</span>
              <div
                class="font-mono text-xl sm:text-2xl font-semibold"
                style={f.highlight ? "color: var(--brand);" : "color: var(--foreground);"}
              >
                {f.body}{f.highlight ? <span class="ml-1 animate-caret">_</span> : null}
              </div>
            </div>
          ))}
        </div>

        <!-- footer -->
        <div class="px-5 py-3 flex items-center justify-between text-[11px] text-muted-foreground bg-card">
          <span class="font-mono">m=4kg · v=10m/s</span>
          <span class="inline-flex items-center gap-1.5">
            <span class="h-1.5 w-1.5 rounded-full animate-ping" style="background: var(--brand);" />
            Recomputed instantly
          </span>
        </div>
      </div>

      <!-- feature pills -->
      <div class="reveal-on-scroll mt-10 grid grid-cols-1 sm:grid-cols-3 gap-3 max-w-3xl mx-auto">
        {[
          { icon: "zap",       title: "Live substitution",   body: "Variables swap in real time as you drag sliders." },
          { icon: "smartphone",title: "Any device",          body: "SVG and Canvas on mobile, full WebGL on desktop." },
          { icon: "link",      title: "Share by URL",        body: "Inputs encoded in the link — share exact calculations." },
        ].map((p) => (
          <div class="flex items-center gap-3 neu-flat rounded-xl px-4 py-3 bg-background">
            <div
              class="flex h-9 w-9 items-center justify-center rounded-lg shrink-0"
              style="background: var(--brand-soft); color: var(--brand);"
            >
              <Icon name={p.icon} size={16} />
            </div>
            <div class="min-w-0">
              <div class="font-semibold text-sm">{p.title}</div>
              <div class="text-[11px] text-muted-foreground truncate">{p.body}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─────────────────────── CATEGORIES ─────────────────────── -->
  <section class="w-full page-wrap py-20 sm:py-24">
    <div class="reveal-on-scroll mb-10 sm:mb-12">
      <div class="text-[11px] uppercase tracking-widest text-muted-foreground mb-3">— Browse</div>
      <h2 class="font-display font-bold text-3xl sm:text-4xl tracking-tight mb-2">By category</h2>
      <p class="text-sm sm:text-base text-muted-foreground">Five disciplines. One interface. Pick a domain.</p>
    </div>

    <div class="reveal-on-scroll grid grid-cols-2 sm:grid-cols-5 gap-3 sm:gap-4">
      {categories.map((c) => (
        <a
          href={`/formulas/${c.key}`}
          class="group category-card relative flex flex-col items-start gap-4 neu-raised rounded-2xl p-6 formula-card-hover"
        >
          <div
            class="category-card-icon neu-inset flex h-11 w-11 items-center justify-center rounded-xl"
          >
            <Icon name={c.icon} size={20} class="transition-transform group-hover:scale-110" />
          </div>

          <div>
            <div class="font-display font-semibold text-base sm:text-lg leading-tight transition-colors group-hover:text-[var(--brand)]">
              {c.label}
            </div>
            <div class="text-[11px] uppercase tracking-widest text-muted-foreground mt-1">
              {categoryCounts[c.key]} tools
            </div>
          </div>

          <span
            class="absolute top-5 right-5 text-muted-foreground transition-transform group-hover:translate-x-0.5 group-hover:text-[var(--brand)]"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- ─────────────────────── VALUE PROPS ─────────────────────── -->
  <section class="bg-card">
    <div class="w-full page-wrap py-20 sm:py-24">
      <div class="reveal-on-scroll mb-12 text-center max-w-xl mx-auto">
        <div class="text-[11px] uppercase tracking-widest text-muted-foreground mb-3">— Why {SITE_NAME}</div>
        <h2 class="font-display font-bold text-3xl sm:text-4xl tracking-tight">Built for intuition, not memorization.</h2>
      </div>

      <div class="reveal-on-scroll grid md:grid-cols-3 gap-5">
        {[
          {
            icon: "target",
            title: "Live substitution",
            body: "Watch values get plugged into the formula in real time. Every card is a live demo — no clicks needed.",
          },
          {
            icon: "smartphone",
            title: "Works on any device",
            body: "SVG and Canvas on mobile, full 3D WebGL on desktop. Every formula adapts to your screen.",
          },
          {
            icon: "link",
            title: "Shareable results",
            body: "Inputs are encoded in the URL. Share your exact calculation with a single link.",
          },
        ].map((item) => (
          <div
            class="group flex flex-col gap-4 neu-raised rounded-2xl p-7 formula-card-hover bg-background"
          >
            <div
              class="flex h-11 w-11 items-center justify-center rounded-xl"
              style="background: var(--brand-soft); color: var(--brand);"
            >
              <Icon name={item.icon} size={22} />
            </div>
            <div class="font-display font-semibold text-lg leading-snug">{item.title}</div>
            <div class="text-muted-foreground text-sm leading-relaxed">{item.body}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─────────────────────── FINAL CTA ─────────────────────── -->
  <section>
    <div class="w-full page-wrap py-20 sm:py-28">
      <div
        class="reveal-on-scroll relative overflow-hidden neu-inset rounded-3xl p-10 sm:p-16 text-center bg-background text-foreground"
      >
        <!-- decorative ring -->
        <div
          class="absolute -top-32 -right-32 w-72 h-72 rounded-full opacity-10"
          style="background: radial-gradient(circle, var(--brand), transparent 70%);"
        />
        <div
          class="absolute -bottom-32 -left-32 w-72 h-72 rounded-full opacity-10"
          style="background: radial-gradient(circle, var(--brand), transparent 70%);"
        />

        <div class="relative max-w-2xl mx-auto">
          <div class="inline-flex items-center gap-2 neu-flat rounded-full px-3.5 py-1.5 text-xs font-medium mb-6"
               style="color: var(--brand); background: var(--brand-soft);">
            <Icon name="rocket" size={12} />
            Ready when you are
          </div>

          <h2 class="font-display font-bold text-3xl sm:text-5xl tracking-tight mb-5 leading-tight">
            Start exploring<br />
            <span style="color: var(--brand);">{all.length}+ formulas</span> in seconds.
          </h2>
          <p class="text-sm sm:text-base mb-9 text-muted-foreground max-w-lg mx-auto">
            No sign-up. No paywall. Just open a visualizer and start moving sliders.
          </p>

          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a
              href="/formulas"
              class="inline-flex items-center justify-center gap-2 neu-raised neu-interactive rounded-xl px-7 py-3.5 font-semibold text-sm bg-primary text-primary-foreground"
            >
              Browse all formulas
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            <a
              href="/about"
              class="inline-flex items-center justify-center gap-2 neu-flat neu-interactive rounded-xl px-7 py-3.5 font-semibold text-sm bg-secondary text-secondary-foreground"
            >
              How it works
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Scroll-reveal observer (inline, no extra JS bundle) ─── -->
  <script is:inline>
    (function initRevealObserver() {
      if (typeof window === "undefined") return;
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        document.querySelectorAll(".reveal-on-scroll").forEach((el) => el.classList.add("is-visible"));
        return;
      }

      const els = document.querySelectorAll(".reveal-on-scroll");
      if (!("IntersectionObserver" in window)) {
        els.forEach((el) => el.classList.add("is-visible"));
        return;
      }

      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add("is-visible");
              io.unobserve(e.target);
            }
          }
        },
        { rootMargin: "0px 0px -8% 0px", threshold: 0.05 },
      );
      els.forEach((el) => io.observe(el));
    })();

    document.addEventListener("astro:after-swap", function () {
      document.querySelectorAll(".reveal-on-scroll").forEach((el) => el.classList.remove("is-visible"));
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        document.querySelectorAll(".reveal-on-scroll").forEach((el) => el.classList.add("is-visible"));
        return;
      }
      const els = document.querySelectorAll(".reveal-on-scroll");
      if (!("IntersectionObserver" in window)) {
        els.forEach((el) => el.classList.add("is-visible"));
        return;
      }
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add("is-visible");
              io.unobserve(e.target);
            }
          }
        },
        { rootMargin: "0px 0px -8% 0px", threshold: 0.05 },
      );
      els.forEach((el) => io.observe(el));
    });
  </script>
</BaseLayout>
