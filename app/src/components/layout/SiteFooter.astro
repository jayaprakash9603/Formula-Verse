---
import Icon from "@/components/icons/Icon.astro";
import { SITE_NAME, SITE_URL } from "@/lib/site";

const MATH_LINKS = [
  { href: "/tools/pythagorean-theorem-visualizer", label: "Pythagorean Theorem" },
  { href: "/tools/circle-area-visualizer", label: "Circle Area" },
  { href: "/tools/quadratic-formula-visualizer", label: "Quadratic Formula" },
  { href: "/tools/sphere-volume-visualizer", label: "Sphere Volume" },
  { href: "/tools/pythagorean-3d-theorem", label: "3D Pythagorean" },
];

const PHYSICS_LINKS = [
  { href: "/tools/einsteins-emc2-visualizer", label: "Einstein's E=mc²" },
  { href: "/tools/newtons-second-law-visualizer", label: "Newton's Second Law" },
  { href: "/tools/kinetic-energy-visualizer", label: "Kinetic Energy" },
  { href: "/tools/wave-equation-visualizer", label: "Wave Equation" },
];

const OTHER_LINKS = [
  { href: "/tools/ohms-law-visualizer", label: "Ohm's Law" },
  { href: "/tools/ideal-gas-law-visualizer", label: "Ideal Gas Law" },
  { href: "/formulas", label: "All Formulas List" },
  { href: "/about", label: "About FormulaVerse" },
];

const SOCIALS = [
  { href: "https://github.com", name: "github", label: "GitHub" },
  { href: "https://linkedin.com", name: "linkedin", label: "LinkedIn" },
  { href: "https://twitter.com", name: "twitter", label: "Twitter" },
];

const POLICIES = [
  { href: "/privacy", label: "Privacy Policy" },
  { href: "/privacy", label: "Terms & Conditions" },
  { href: "/privacy", label: "Cookie Policy" },
  { href: "/about", label: "Disclaimer" },
  { href: "/about", label: "Contact" },
];
---
<footer class="mt-28 w-full" style="background: var(--background);">
  <div class="w-full neu-flat border-t border-[var(--hairline)] bg-card">
    <!-- Main Grid Zone with Sectioned Columns -->
    <div class="w-full px-4 sm:px-6 md:px-10 py-16 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12 items-start">

    <!-- Column 1: Brand Block & Overview -->
    <div class="space-y-6">
      <div>
        <a href="/" class="inline-flex items-center gap-3 font-display font-bold text-xl text-foreground group">
          <span
            class="flex h-8 w-8 items-center justify-center rounded-lg neu-raised transition-transform group-hover:scale-105"
            style="background: var(--brand); color: #ffffff;"
          >
            <Icon name="globe" size={18} />
          </span>
          <span class="tracking-tight">{SITE_NAME}</span>
        </a>
      </div>
      
      <p class="text-xs leading-relaxed text-muted-foreground max-w-sm">
        FormulaVerse keeps the useful stuff in one place: interactive formula visualizers for math, physics, finance, chemistry, and engineering you can open and use right away. Free, open-access, and runs fully in your web browser.
      </p>

      <div class="pt-2">
        <a
          href="/formulas"
          class="inline-flex items-center justify-center gap-2 px-5 py-2.5 text-xs font-bold neu-raised neu-interactive rounded-xl bg-card text-foreground hover:text-primary transition-colors"
        >
          Browse All Categories
          <span class="text-primary font-bold">→</span>
        </a>
      </div>

      <!-- Social Icons styled as rounded neu buttons -->
      <div class="flex items-center gap-3 pt-4">
        {SOCIALS.map((s) => (
          <a
            href={s.href}
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-9 w-9 items-center justify-center rounded-full neu-flat neu-interactive bg-card text-muted-foreground hover:text-primary transition-colors"
            title={s.label}
          >
            <Icon name={s.name} size={15} />
          </a>
        ))}
      </div>
    </div>

    <!-- Column 2: Math Section -->
    <div class="space-y-5">
      <div class="text-[11px] uppercase tracking-widest font-bold text-foreground flex items-center gap-2">
        <span class="h-4 w-1 rounded-full bg-primary inline-block"></span>
        Mathematics
      </div>
      <ul class="space-y-3">
        {MATH_LINKS.map((link) => (
          <li>
            <a
              href={link.href}
              class="group flex items-center text-xs text-muted-foreground hover:text-foreground transition-colors py-1"
            >
              <span class="text-primary opacity-0 group-hover:opacity-100 transition-opacity mr-2 select-none">→</span>
              <span class="group-hover:translate-x-0.5 transition-transform duration-200">{link.label}</span>
            </a>
          </li>
        ))}
        <li class="pt-2">
          <a
            href="/formulas/math"
            class="inline-flex items-center gap-1.5 text-xs font-bold text-primary hover:underline"
          >
            View more math <span class="text-xs">→</span>
          </a>
        </li>
      </ul>
    </div>

    <!-- Column 3: Physics Section -->
    <div class="space-y-5">
      <div class="text-[11px] uppercase tracking-widest font-bold text-foreground flex items-center gap-2">
        <span class="h-4 w-1 rounded-full bg-primary inline-block"></span>
        Physics
      </div>
      <ul class="space-y-3">
        {PHYSICS_LINKS.map((link) => (
          <li>
            <a
              href={link.href}
              class="group flex items-center text-xs text-muted-foreground hover:text-foreground transition-colors py-1"
            >
              <span class="text-primary opacity-0 group-hover:opacity-100 transition-opacity mr-2 select-none">→</span>
              <span class="group-hover:translate-x-0.5 transition-transform duration-200">{link.label}</span>
            </a>
          </li>
        ))}
        <li class="pt-2">
          <a
            href="/formulas/physics"
            class="inline-flex items-center gap-1.5 text-xs font-bold text-primary hover:underline"
          >
            View more physics <span class="text-xs">→</span>
          </a>
        </li>
      </ul>
    </div>

    <!-- Column 4: Info & Other Science -->
    <div class="space-y-5">
      <div class="text-[11px] uppercase tracking-widest font-bold text-foreground flex items-center gap-2">
        <span class="h-4 w-1 rounded-full bg-primary inline-block"></span>
        Science & Info
      </div>
      <ul class="space-y-3">
        {OTHER_LINKS.map((link) => (
          <li>
            <a
              href={link.href}
              class="group flex items-center text-xs text-muted-foreground hover:text-foreground transition-colors py-1"
            >
              <span class="text-primary opacity-0 group-hover:opacity-100 transition-opacity mr-2 select-none">→</span>
              <span class="group-hover:translate-x-0.5 transition-transform duration-200">{link.label}</span>
            </a>
          </li>
        ))}
        <li class="pt-2">
          <a
            href="/formulas"
            class="inline-flex items-center gap-1.5 text-xs font-bold text-primary hover:underline"
          >
            View all formulas <span class="text-xs">→</span>
          </a>
        </li>
      </ul>
    </div>

  </div>

  <!-- Bottom Section with Sunken Well, Policy Links, and Back to Top -->
  <div class="w-full px-4 sm:px-6 md:px-10 pb-12">
    <div class="neu-inset rounded-2xl p-6 bg-background flex flex-col lg:flex-row justify-between items-center gap-6 text-xs">
      
      <!-- Copyright text on left -->
      <div class="text-muted-foreground/80 font-mono text-center lg:text-left">
        © {new Date().getFullYear()} {SITE_NAME} by J Jaya Prakash. All rights reserved.
      </div>

      <!-- Policy navigation in center -->
      <nav class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-muted-foreground">
        {POLICIES.map((p) => (
          <a
            href={p.href}
            class="hover:text-foreground hover:underline transition-colors text-[11px] font-semibold"
          >
            {p.label}
          </a>
        ))}
      </nav>

      <!-- URL link & Back-to-Top on right -->
      <div class="flex items-center gap-4">
        <span class="hidden sm:inline text-muted-foreground/60 font-mono text-[10px]">
          Free to use · Runs in your browser
        </span>
        <a
          href={SITE_URL}
          class="font-mono text-primary hover:underline neu-flat px-3.5 py-2 rounded-xl bg-card text-[11px] font-bold"
        >
          {SITE_URL.replace("https://", "")}
        </a>

        <!-- Back to Top Rounded Pill Button -->
        <button
          onclick="window.scrollTo({ top: 0, behavior: 'smooth' })"
          class="flex h-9 w-9 items-center justify-center rounded-full neu-raised neu-interactive bg-card text-primary transition-colors cursor-pointer"
          aria-label="Back to top"
          title="Scroll to top"
        >
          <Icon name="arrow-up" size={16} />
        </button>
      </div>

    </div>
  </div>
  </div>
</footer>
