---
import BaseLayout from "./BaseLayout.astro";
import Breadcrumbs from "@/components/layout/Breadcrumbs.astro";
import SubPageNav from "@/components/tool/SubPageNav.astro";
import JsonLd from "@/components/seo/JsonLd.astro";
import FormulaSidebar from "@/components/layout/FormulaSidebar";
import {
  buildBreadcrumbJsonLd,
  buildSoftwareAppJsonLd,
  buildHowToJsonLd,
  buildFaqJsonLd,
} from "@/lib/seo";
import { SITE_URL } from "@/lib/site";
import { getLiveFormulas } from "@/lib/formulas";
import type { FormulaVisualizerConfig } from "@/engines/formula-visualizer/types";

interface Props {
  config: FormulaVisualizerConfig;
  subPage: "index" | "explain" | "guide" | "examples" | "faq";
  title?: string;
}

const { config, subPage, title } = Astro.props;

const baseUrl = `${SITE_URL}/tools/${config.slug}`;
const pageUrl = subPage === "index" ? baseUrl : `${baseUrl}/${subPage}`;

const subPageLabels: Record<string, string> = {
  explain: "Explain",
  guide: "Guide",
  examples: "Examples",
  faq: "FAQ",
};

const crumbs = [
  { label: "Home", href: "/" },
  { label: "Formulas", href: "/formulas" },
  { label: config.category.charAt(0).toUpperCase() + config.category.slice(1), href: `/formulas/${config.category}` },
  { label: config.name, ...(subPage !== "index" ? { href: baseUrl } : {}) },
  ...(subPage !== "index" ? [{ label: subPageLabels[subPage] ?? subPage }] : []),
];

const pageTitle = title ?? config.seo.title;

const jsonLdBlocks = [
  buildBreadcrumbJsonLd(crumbs.map((c) => ({ name: c.label, url: (c as { href?: string }).href ? `${SITE_URL}${(c as { href: string }).href}` : undefined }))),
  buildSoftwareAppJsonLd(config, baseUrl),
  ...(subPage === "guide" ? [buildHowToJsonLd(config, pageUrl)] : []),
  ...(subPage === "faq" ? [buildFaqJsonLd(config, pageUrl)] : []),
];

/* Build sidebar formula data — serialisable (no functions) */
const sidebarFormulas = getLiveFormulas().map((f) => ({
  slug: f.slug,
  name: f.name,
  category: f.category,
  shortForm: f.shortForm,
  difficulty: f.difficulty,
}));
---
<BaseLayout
  title={pageTitle}
  description={config.seo.description}
  ogImage={`/og/${config.slug}.png`}
  canonical={pageUrl}
  hideFooter={subPage === "index"}
>
  <Fragment slot="head">
    {jsonLdBlocks.map((block) => <JsonLd data={block} />)}
    <slot name="head" />
  </Fragment>

  <div class="tool-page tool-page--sub">
  <!-- Breadcrumbs + sub-page nav — full width, directly below site header -->
  <div class="w-full px-4 sm:px-6 tool-topbar neu-flat border-b border-[var(--hairline)]">
    <Breadcrumbs items={crumbs} />
    <div class="pb-2">
      <SubPageNav slug={config.slug} current={subPage} />
    </div>
  </div>

  <!-- Full-width flex wrapper: sidebar + main -->
  <div class="flex w-full tool-layout-wrap">

    <!-- Sidebar — sticky on desktop, slide-over on mobile -->
    <FormulaSidebar
      formulas={sidebarFormulas}
      currentSlug={config.slug}
      client:load
    />

    <!-- Main content area -->
    <div class="flex-1 min-w-0 overflow-x-hidden flex flex-col">
      <div class="flex-1">
        <slot />
      </div>
    </div>
  </div>
  </div>
</BaseLayout>

<style>
  .tool-page {
    --fv-header-h: 3.5rem;
    --fv-topbar-h: 2.25rem;
    --fv-stack-top: calc(var(--fv-header-h) + var(--fv-topbar-h));
  }
  .tool-page--sub {
    --fv-topbar-h: 4.5rem;
  }
  .tool-layout-wrap {
    min-height: calc(100vh - var(--fv-stack-top));
  }
  .tool-topbar {
    background: var(--background);
    position: sticky;
    top: var(--fv-header-h);
    z-index: 20;
  }
</style>
