---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE_NAME, SITE_URL } from "@/lib/site";
---
<BaseLayout
  title={`About — ${SITE_NAME}`}
  description={`Learn about ${SITE_NAME}, the interactive formula visualizer for math, physics, finance, chemistry, and engineering.`}
  canonical={`${SITE_URL}/about`}
>
  <div class="w-full page-wrap py-16">
    <h1 class="font-display font-bold text-4xl mb-6">About {SITE_NAME}</h1>
    <div class="space-y-6 text-muted-foreground leading-relaxed">
      <p>
        {SITE_NAME} is a free, open-access collection of interactive formula visualizers built to make STEM education more intuitive.
        Every visualizer lets you adjust variables in real time and see the mathematical relationship animate instantly — no calculator app, no sign-up, no cost.
      </p>
      <p>
        Built with Astro 5, React 19, Tailwind CSS v4, Three.js, and KaTeX. Deployed on Cloudflare Pages for global edge performance.
      </p>
      <p>
        The project is ad-supported to remain free for everyone. If you find it useful, sharing individual tool pages helps others discover it too.
      </p>
      <h2 class="font-display font-semibold text-xl text-foreground mt-8">Technology Stack</h2>
      <ul class="space-y-1.5 text-sm">
        <li>⚡ <strong class="text-foreground">Astro 5</strong> — island architecture for maximum performance</li>
        <li>⚛️ <strong class="text-foreground">React 19</strong> — interactive calculator islands</li>
        <li>🎨 <strong class="text-foreground">Tailwind CSS v4</strong> — utility-first styling</li>
        <li>🧊 <strong class="text-foreground">Three.js / R3F</strong> — WebGL 3D scenes</li>
        <li>✏️ <strong class="text-foreground">KaTeX</strong> — beautiful LaTeX formula rendering</li>
        <li>☁️ <strong class="text-foreground">Cloudflare Pages</strong> — edge-cached global CDN</li>
      </ul>
    </div>
  </div>
</BaseLayout>
