---
import ToolLayout from "@/layouts/ToolLayout.astro";
import { FORMULA_SLUGS_LIVE, getBySlug } from "@/lib/formulas";

export function getStaticPaths() {
  return FORMULA_SLUGS_LIVE.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const config = getBySlug(slug)!;
---
<ToolLayout config={config} subPage="guide">
  <div class="mx-auto w-full max-w-[900px] px-4 sm:px-6 pb-20 pt-4 sm:pt-6">
    <h1 class="font-display font-bold text-3xl sm:text-4xl mb-4">
      How to Use the {config.name} Calculator
    </h1>
    <p class="text-muted-foreground text-lg mb-8">
      A step-by-step guide to using the {config.name} interactive visualizer.
    </p>

    <h2 class="font-display font-semibold text-xl mb-4">Step-by-Step Guide</h2>
    <ol class="space-y-4 mb-10">
      {config.steps.map((step, i) => (
        <li class="flex gap-4">
          <span class="shrink-0 w-7 h-7 rounded-full bg-primary/20 text-primary text-sm font-bold flex items-center justify-center">
            {i + 1}
          </span>
          <p class="text-muted-foreground leading-relaxed pt-0.5">{step}</p>
        </li>
      ))}
    </ol>

    <h2 class="font-display font-semibold text-xl mb-4">Formula Explanation</h2>
    <p class="text-muted-foreground leading-relaxed mb-4">{config.beginnerExplanation}</p>

    <h2 class="font-display font-semibold text-xl mb-4">Real-World Applications</h2>
    <ul class="space-y-2 mb-10">
      {config.realWorld.map((item) => (
        <li class="flex gap-2 text-muted-foreground text-sm leading-relaxed">
          <span class="text-primary mt-0.5 shrink-0">→</span>
          <span>{item}</span>
        </li>
      ))}
    </ul>

    <div class="pt-6 relative">
      <div class="absolute top-0 left-0 right-0 neu-divider"></div>
      <p class="text-xs text-muted-foreground">
        Ready to start? <a href={`/tools/${config.slug}`} class="text-primary hover:underline">Open the interactive {config.name} visualizer →</a>
      </p>
    </div>
  </div>
</ToolLayout>
